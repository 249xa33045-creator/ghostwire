{
  "expo": {
    "name": "Ghostwire",
    "slug": "ghostwire",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "backgroundColor": "#000000"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.ghostwire.app",
      "minSdkVersion": 26,
      "compileSdkVersion": 35,
      "targetSdkVersion": 35,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Ghostwire needs camera to scan contact QR codes."
        }
      ],
      "expo-sqlite"
    ],
    "scheme": "ghostwire",
    "extra": {
      "eas": {
        "projectId": "103df176-747a-4216-a911-712369d8acff"
      }
    }
  }
}
