{
  "expo": {
    "name": "Ghostwire",
    "slug": "ghostwire",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#000000"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000"
      },
      "package": "com.ghostwire.app",
      "permissions": [
        "CAMERA",
        "ACCESS_WIFI_STATE",
        "CHANGE_WIFI_STATE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CHANGE_NETWORK_STATE",
        "ACCESS_NETWORK_STATE",
        "INTERNET",
        "FOREGROUND_SERVICE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Ghostwire needs camera to scan contact QR codes."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#6d28d9"
        }
      ],
      "expo-sqlite"
    ],
    "scheme": "ghostwire",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "103df176-747a-4216-a911-712369d8acff"
      }
    }
  }
}
